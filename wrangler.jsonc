{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "pure-mitten-site",
  "pages_build_output_dir": "public",
  "compatibility_date": "2026-07-03",
  "vars": {
    "GOOGLE_CALENDAR_TIME_ZONE": "America/Detroit",
